# ========================================================================
# JUSTCALLQUANT - ENVIRONMENT CONFIGURATION (.env)
# ========================================================================

# Keamanan Internal Backend
SECRET_KEY=justcallquant_super_secret_string_2026

# AI Agent Configuration (Otak untuk Agent FA & TA)
# Daftar gratis di Google AI Studio untuk mendapatkan key Gemini
GEMINI_API_KEY=masukkan_api_key_gemini_kamu_disini

# Financial Data Providers (Macro & News Sentiment)
FRED_API_KEY=masukkan_api_key_fred_kamu_disini
ALPHA_VANTAGE_API_KEY=masukkan_api_key_alphavantage_kamu_disini

# Database Configuration (Untuk menyimpan bookmark/cache data)
# Secara default kita pakai SQLite lokal saja yang tidak perlu install apa-apa
DATABASE_URL=sqlite:///./justcallquant.db